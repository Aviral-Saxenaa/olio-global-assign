{
  "name": "olio-global-assign",
  "private": true,
  "version": "1.0.0",
  "description": "Email marketing app monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:api",
    "dev:web": "npm run dev -w @olio/web",
    "dev:api": "npm run dev -w @olio/api",
    "dev:worker": "npm run dev -w @olio/worker",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:generate": "npm run db:generate -w @olio/db",
    "db:push": "npm run db:push -w @olio/db",
    "db:migrate": "npm run db:migrate -w @olio/db",
    "db:seed": "npm run db:seed -w @olio/db"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "tsx": "^4.23.1"
  }
}
